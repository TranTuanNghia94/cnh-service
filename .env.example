# ============================================================
#  CNH BE Service — environment variable template
#  Copy this file to .env and fill in your real values.
#  This file IS committed to git — never put real secrets here.
# ============================================================

# ── Server ───────────────────────────────────────────────────
SERVER_PORT=8080
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=<your_db_password>

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<your_redis_password_or_empty>

# ── Spring Security (built-in basic-auth user) ───────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<your_admin_password>

# ── JWT ──────────────────────────────────────────────────────
# Use a random, high-entropy string of at least 32 characters.
# Generate one with: openssl rand -base64 48
JWT_SECRET=<your_jwt_secret_min_32_chars>
JWT_EXPIRATION=14400000
JWT_REFRESH_EXPIRATION=28800000

# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY=<your_aws_access_key_id>
AWS_SECRET_KEY=<your_aws_secret_access_key>
AWS_S3_BUCKET=<your_s3_bucket_name>
AWS_SES_FROM_EMAIL=<your_ses_verified_email>
AWS_SES_REGION=us-east-1

# ── Azure Storage ────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=<your_azure_connection_string>
AZURE_STORAGE_CONTAINER=cnh-wms

# ── Mail (SMTP) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<your_smtp_username>
MAIL_PASSWORD=<your_smtp_password_or_app_password>

# ── SendGrid ─────────────────────────────────────────────────
SENDGRID_API_KEY=<your_sendgrid_api_key>
SENDGRID_FROM_EMAIL=<your_sendgrid_sender_email>

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# ── OpenTelemetry ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
