<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <!--
        Spring Boot color converter extensions.
    -->
    <conversionRule conversionWord="clr"
                    converterClass="org.springframework.boot.logging.logback.ColorConverter"/>
    <conversionRule conversionWord="wex"
                    converterClass="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/>
    <conversionRule conversionWord="wEx"
                    converterClass="org.springframework.boot.logging.logback.ExtendedWhitespaceThrowableProxyConverter"/>

    <!-- Read values from Spring Environment (application.yml / env vars) -->
    <springProperty scope="context" name="APP_NAME"      source="spring.application.name"       defaultValue="cnh-be-service"/>
    <springProperty scope="context" name="APP_LOG_LEVEL" source="logging.level.com.cnh.ies"     defaultValue="INFO"/>
    <springProperty scope="context" name="APP_ENV"       source="spring.profiles.active"        defaultValue="dev"/>

    <property name="LOG_DIR"     value="logs"/>
    <property name="LOG_FILE"    value="${LOG_DIR}/${APP_NAME}.log"/>
    <property name="ARCHIVE_DIR" value="${LOG_DIR}/archive"/>

    <!--
        MDC Keys available in all logs (set by RequestResponseLoggingFilter):
          - requestId: unique per request (shortened UUID)
          - correlationId: propagated from caller or same as requestId
          - userId: authenticated user
          - method: HTTP method
          - uri: request URI
          - elapsedMs: request duration
          - status: HTTP status code
    -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [rid=%X{requestId:-} cid=%X{correlationId:-} uid=%X{userId:-}] - %msg%n"/>

    <property name="COLOR_PATTERN"
              value="%clr(%d{HH:mm:ss.SSS}){faint} %clr(%-5level){highlight} %clr([%X{requestId:-}]){blue} %clr(%logger{24}){cyan} - %msg%n"/>

    <!-- ═══════════════════════════════════════════════════════════════════
         CONSOLE APPENDERS
         ═══════════════════════════════════════════════════════════════════ -->
    
    <!-- DEV: Colored, human-readable console output -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${COLOR_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>
    </springProfile>

    <!-- PROD/STAGING: JSON structured logging for ELK/Datadog/CloudWatch -->
    <springProfile name="prod,staging,production">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <includeMdcKeyName>correlationId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>method</includeMdcKeyName>
                <includeMdcKeyName>uri</includeMdcKeyName>
                <includeMdcKeyName>elapsedMs</includeMdcKeyName>
                <includeMdcKeyName>status</includeMdcKeyName>
                <customFields>{"service":"${APP_NAME}","env":"${APP_ENV}"}</customFields>
                <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>
            </encoder>
        </appender>
    </springProfile>

    <!-- Fallback for other profiles: plain text -->
    <springProfile name="!dev &amp; !prod &amp; !staging &amp; !production">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>
    </springProfile>

    <!-- ═══════════════════════════════════════════════════════════════════
         FILE APPENDERS
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Plain text file for dev -->
    <springProfile name="dev">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_FILE}</file>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${ARCHIVE_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>7</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
        </appender>
    </springProfile>

    <!-- JSON file for prod (easier to parse with log aggregators) -->
    <springProfile name="prod,staging,production">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_FILE}</file>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <includeMdcKeyName>correlationId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>method</includeMdcKeyName>
                <includeMdcKeyName>uri</includeMdcKeyName>
                <includeMdcKeyName>elapsedMs</includeMdcKeyName>
                <includeMdcKeyName>status</includeMdcKeyName>
                <customFields>{"service":"${APP_NAME}","env":"${APP_ENV}"}</customFields>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${ARCHIVE_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>5GB</totalSizeCap>
            </rollingPolicy>
        </appender>
    </springProfile>

    <!-- Fallback FILE for other profiles -->
    <springProfile name="!dev &amp; !prod &amp; !staging &amp; !production">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_FILE}</file>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${ARCHIVE_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>3GB</totalSizeCap>
            </rollingPolicy>
        </appender>
    </springProfile>

    <!-- Async wrapper keeps request threads unblocked during file I/O -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>1024</queueSize>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="FILE"/>
    </appender>

    <!-- ═══════════════════════════════════════════════════════════════════
         APPLICATION LOGGERS
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Main application logger -->
    <logger name="com.cnh.ies" level="${APP_LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>

    <!-- HTTP logging filter - always INFO to capture request/response -->
    <logger name="com.cnh.ies.config.RequestResponseLoggingFilter" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>

    <!-- Service method logging (AOP) -->
    <logger name="com.cnh.ies.config.LoggingAspect" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>

    <!-- Spring Security -->
    <logger name="org.springframework.security" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>

    <!-- ═══════════════════════════════════════════════════════════════════
         HIBERNATE SQL LOGGING
         ═══════════════════════════════════════════════════════════════════ -->

    <springProfile name="dev">
        <!-- Set to DEBUG to see SQL, TRACE to see bound parameters -->
        <logger name="org.hibernate.SQL" level="ERROR" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </logger>
        <logger name="org.hibernate.orm.jdbc.bind" level="ERROR" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </logger>
    </springProfile>

    <springProfile name="!dev">
        <logger name="org.hibernate.SQL" level="WARN" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </logger>
        <logger name="org.hibernate.orm.jdbc.bind" level="WARN" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </logger>
    </springProfile>

    <!-- ═══════════════════════════════════════════════════════════════════
         FRAMEWORK NOISE SUPPRESSION
         ═══════════════════════════════════════════════════════════════════ -->

    <logger name="org.springframework.web.servlet.mvc.method.annotation" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>
    <logger name="com.zaxxer.hikari" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>
    <logger name="org.apache.catalina" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>
    <logger name="org.springframework.boot.actuate" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>

    <!-- ═══════════════════════════════════════════════════════════════════
         ROOT LOGGER
         ═══════════════════════════════════════════════════════════════════ -->

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </root>

</configuration>
